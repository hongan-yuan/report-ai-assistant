# OpenAI 兼容 API（OpenAI / DeepSeek / 通义 / Ollama / vLLM 等）
OPENAI_API_KEY=sk-local-anything
OPENAI_BASE_URL=http://127.0.0.1:8001/v1
OPENAI_MODEL=Model/Qwen3.6-35B-A3B

# Qwen3.6 + vLLM 推荐参数
OPENAI_TEMPERATURE=0.6
OPENAI_TOP_P=0.95
OPENAI_TOP_K=20
OPENAI_MIN_P=0
OPENAI_MAX_TOKENS=32768
OPENAI_PRESENCE_PENALTY=1.5
OPENAI_REPETITION_PENALTY=1.0
VLLM_EXTRA_BODY=true
QWEN_ENABLE_THINKING=true
QWEN_PRESERVE_THINKING=false
# 可追加任意 vLLM extra_body JSON，会和上述参数合并
# OPENAI_EXTRA_BODY_JSON={"guided_json":{}}

# 默认检测报告目录（前端也可覆盖）
REPORT_DIRECTORY=/home/lg/docs

# 单次分析最多纳入的文件数、每个文件最大字符数
MAX_FILES=50
MAX_CHARS_PER_FILE=30000
